<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="FTP Sunucusu"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tv_ip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="IP: Bekleniyor..."
        android:textSize="16sp"
        android:padding="12dp"
        android:background="#E3F2FD"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⏹ Sunucu kapalı"
        android:textSize="16sp"
        android:gravity="center"
        android:padding="12dp"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/et_port"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Port (varsayılan: 2121)"
        android:inputType="number"
        android:text="2121"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/et_user"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Kullanıcı Adı"
        android:text="admin"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/et_pass"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Şifre"
        android:text="1234"
        android:inputType="textPassword"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btn_start"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sunucuyu Başlat"
        android:backgroundTint="#1565C0"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btn_stop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sunucuyu Durdur"
        android:backgroundTint="#C62828"
        android:textColor="#FFFFFF"
        android:enabled="false"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="💡 PC'den bağlanmak için FileZilla veya WinSCP kullanın"
        android:textSize="12sp"
        android:textColor="#757575"
        android:layout_marginTop="16dp"
        android:gravity="center"/>

</LinearLayout>
